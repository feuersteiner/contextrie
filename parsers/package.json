{
  "name": "@contextrie/parsers",
  "version": "0.1.0",
  "description": "Node-based file parsers that return Contextrie core source instances.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    }
  },
  "files": [
    "index.ts",
    "README.md",
    "CONTRIBUTING.md",
    "sources/**/*.ts",
    "utils/**/*.ts"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck"
  },
  "dependencies": {
    "@contextrie/core": "^0.2.1",
    "human-id": "^4.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "typescript": "^5"
  }
}
